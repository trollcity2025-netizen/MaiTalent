# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PayPal Configuration
# Get these from your PayPal Developer Dashboard (https://developer.paypal.com)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# PayPal Payouts Configuration  
PAYPAL_PAYOUTS_CLIENT_ID=your-payouts-client-id
PAYPAL_PAYOUTS_CLIENT_SECRET=your-payouts-client-secret

# YouTube API Configuration (Frontend)
VITE_YOUTUBE_CLIENT_ID=your-youtube-client-id
VITE_YOUTUBE_REFRESH_TOKEN=your-refresh-token

# App Settings
VITE_APP_URL=http://localhost:5173

# ============================================
# SUPABASE EDGE FUNCTION ENV VARS
# ============================================
# These should be set in your Supabase project dashboard
# under Settings > Edge Functions

# YOUTUBE_CLIENT_ID=your-youtube-client-id
# YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
# YOUTUBE_REFRESH_TOKEN=your-refresh-token (get from OAuth flow)
# YOUTUBE_CHANNEL_ID=your-channel-id

VITE_AGORA_APP_ID=your-agora-app-id
VITE_AGORA_APP_CERTIFICATE=your-agora-certificate
VITE_MUX_TOKEN_ID=your-mux-token-id
